{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "untitled-p-project",
    "author": "tastyForReal",
    "description": "Untitled P Project - A \"Piano Tiles 2\" FOSS clone.",
    "license": "MIT",
    "keywords": [
        "electron",
        "webgpu",
        "game",
        "typescript"
    ],
    "main": "dist/main.js",
    "version": "0.0.1",
    "private": "true",
    "devDependencies": {
        "@types/node": "^25.3.3",
        "@webgpu/types": "^0.1.69",
        "electron": "^40.6.1",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3"
    },
    "scripts": {
        "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.renderer.json",
        "dev": "bun run build && electron .",
        "dev:bot": "bun run build && electron . --bot",
        "format": "prettier --write src/**/*.ts",
        "start": "electron .",
        "start:bot": "electron . --bot"
    }
}
